<?xml version="1.0" encoding="utf-8"?>
<!--
  Main.xaml — ReFramework State Machine
  Process: {{PROCESS_NAME}}
  {{PROCESS_DESCRIPTION}}
  Generated by ReFramework Generator v{{VERSION}} on {{CURRENT_DATE}}
-->
<Activity
  mc:Ignorable="sap sap2010"
  x:Class="UiPath.ReFramework.Main"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
  xmlns:s="clr-namespace:System;assembly=mscorlib"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:uia="clr-namespace:UiPath.Core;assembly=UiPath.Core"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="in_OrchestratorQueueName" Type="InArgument(x:String)"
      sap2010:Annotation.AnnotationText="Optional: pass Orchestrator queue name as argument to override Config.xlsx value." />
  </x:Members>
  <mva:VisualBasic.Settings>
    <mva:VisualBasicSettings>
      <mva:VisualBasicSettings.ImportedNamespaces>
        <mva:VisualBasicImportReference Assembly="mscorlib" Import="System" />
        <mva:VisualBasicImportReference Assembly="mscorlib" Import="System.Collections.Generic" />
        <mva:VisualBasicImportReference Assembly="UiPath.Core" Import="UiPath.Core" />
      </mva:VisualBasicSettings.ImportedNamespaces>
    </mva:VisualBasicSettings>
  </mva:VisualBasic.Settings>

  <StateMachine
    sap2010:Annotation.AnnotationText="{{PROCESS_NAME}}&#xA;{{PROCESS_DESCRIPTION}}&#xA;&#xA;Transaction Source: {{TRANSACTION_SOURCE}}&#xA;Max Retries: {{MAX_RETRY_NUMBER}}&#xA;Generated: {{CURRENT_DATE}}"
    DisplayName="{{PROCESS_NAME}} — ReFramework">

    <StateMachine.Variables>
      <Variable x:TypeArguments="scg:Dictionary(x:String, x:Object)" Name="Config" />
      <Variable x:TypeArguments="ui:QueueItem" Name="TransactionItem" />
      <Variable x:TypeArguments="x:Int32" Default="0" Name="TransactionNumber" />
      <Variable x:TypeArguments="x:Int32" Default="0" Name="ConsecutiveSystemExceptions" />
      <Variable x:TypeArguments="x:String" Default="&quot;&quot;" Name="SystemException" />
    </StateMachine.Variables>

    <!-- ═══════════════════════ INIT STATE ════════════════════════ -->
    <State x:Name="Init"
      sap2010:Annotation.AnnotationText="1. Read Config.xlsx&#xA;2. Kill any lingering app processes (clean start)&#xA;3. Open all applications&#xA;4. Reset ConsecutiveSystemExceptions counter"
      DisplayName="Init">
      <State.Entry>
        <Sequence DisplayName="Initialize Process">
          <TryCatch DisplayName="Try Initialize">
            <TryCatch.Try>
              <Sequence>
                <If Condition="[Config Is Nothing]" DisplayName="First run? Read Config file">
                  <If.Then>
                    <Sequence DisplayName="First run">
                      <ui:InvokeWorkflowFile DisplayName="Invoke InitAllSettings"
                        WorkflowFileName="Framework\InitAllSettings.xaml" UnSafe="False">
                        <ui:InvokeWorkflowFile.Arguments>
                          <InArgument x:TypeArguments="x:String" x:Key="in_ConfigFile">Data\Config.xlsx</InArgument>
                          <InArgument x:TypeArguments="s:String[]" x:Key="in_ConfigSheets">[{"Settings", "Constants"}]</InArgument>
                          <OutArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="out_Config">[Config]</OutArgument>
                        </ui:InvokeWorkflowFile.Arguments>
                      </ui:InvokeWorkflowFile>
                      <ui:InvokeWorkflowFile DisplayName="Invoke KillAllProcesses (first run)"
                        WorkflowFileName="Framework\KillAllProcesses.xaml" UnSafe="False" />
                    </Sequence>
                  </If.Then>
                </If>
                <ui:InvokeWorkflowFile DisplayName="Invoke InitAllApplications"
                  WorkflowFileName="Framework\InitAllApplications.xaml" UnSafe="False">
                  <ui:InvokeWorkflowFile.Arguments>
                    <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
                  </ui:InvokeWorkflowFile.Arguments>
                </ui:InvokeWorkflowFile>
                <ui:AddLogFields DisplayName="Add log fields">
                  <ui:AddLogFields.Fields>
                    <InArgument x:TypeArguments="x:String" x:Key="businessProcessName">{{PROCESS_NAME}}</InArgument>
                  </ui:AddLogFields.Fields>
                </ui:AddLogFields>
                <Assign DisplayName="Reset ConsecutiveSystemExceptions">
                  <Assign.To><OutArgument x:TypeArguments="x:Int32">[ConsecutiveSystemExceptions]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:Int32">0</InArgument></Assign.Value>
                </Assign>
                <Assign DisplayName="Reset SystemException flag">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[SystemException]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">&quot;&quot;</InArgument></Assign.Value>
                </Assign>
              </Sequence>
            </TryCatch.Try>
            <TryCatch.Catches>
              <Catch x:TypeArguments="x:Exception">
                <ActivityAction x:TypeArguments="x:Exception">
                  <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="x:Exception" Name="initException" />
                  </ActivityAction.Argument>
                  <Sequence>
                    <ui:LogMessage Level="Fatal"
                      Message="['[{{PROCESS_NAME}}] INIT FAILED: ' + initException.Message + Environment.NewLine + initException.StackTrace]"
                      DisplayName="Log init failure" />
                    <Assign DisplayName="Set SystemException for End transition">
                      <Assign.To><OutArgument x:TypeArguments="x:String">[SystemException]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[initException.Message]</InArgument></Assign.Value>
                    </Assign>
                    <Assign DisplayName="Max out ConsecutiveSystemExceptions to force End">
                      <Assign.To><OutArgument x:TypeArguments="x:Int32">[ConsecutiveSystemExceptions]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:Int32">{{MAX_RETRY_NUMBER}}</InArgument></Assign.Value>
                    </Assign>
                  </Sequence>
                </ActivityAction>
              </Catch>
            </TryCatch.Catches>
          </TryCatch>
        </Sequence>
      </State.Entry>
      <State.Transitions>
        <Transition DisplayName="Init failed → End" To="End">
          <Transition.Condition>[ConsecutiveSystemExceptions >= {{MAX_RETRY_NUMBER}}]</Transition.Condition>
        </Transition>
        <Transition DisplayName="Init OK → GetTransactionData" To="GetTransactionData">
          <Transition.Condition>[ConsecutiveSystemExceptions &lt; {{MAX_RETRY_NUMBER}}]</Transition.Condition>
        </Transition>
      </State.Transitions>
    </State>

    <!-- ════════════════ GET TRANSACTION DATA STATE ════════════════ -->
    <State x:Name="GetTransactionData"
      sap2010:Annotation.AnnotationText="Retrieve next transaction from {{TRANSACTION_SOURCE}}.&#xA;TransactionItem = Nothing signals no more data → End Process."
      DisplayName="Get Transaction Data">
      <State.Entry>
        <Sequence DisplayName="Get Next Transaction">
          <ui:InvokeWorkflowFile DisplayName="Invoke GetTransactionData"
            WorkflowFileName="Framework\GetTransactionData.xaml" UnSafe="False">
            <ui:InvokeWorkflowFile.Arguments>
              <InArgument x:TypeArguments="x:Int32" x:Key="in_TransactionNumber">[TransactionNumber]</InArgument>
              <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
              <OutArgument x:TypeArguments="ui:QueueItem" x:Key="out_TransactionItem">[TransactionItem]</OutArgument>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>
        </Sequence>
      </State.Entry>
      <State.Transitions>
        <Transition DisplayName="New item → Process" To="Process">
          <Transition.Condition>[TransactionItem IsNot Nothing]</Transition.Condition>
        </Transition>
        <Transition DisplayName="No more items → End" To="End">
          <Transition.Condition>[TransactionItem Is Nothing]</Transition.Condition>
        </Transition>
      </State.Transitions>
    </State>

    <!-- ══════════════ PROCESS TRANSACTION STATE ══════════════════ -->
    <State x:Name="Process"
      sap2010:Annotation.AnnotationText="Execute business logic for current transaction.&#xA;BusinessRuleException → Failed, no retry.&#xA;ApplicationException → Failed, retry up to {{MAX_RETRY_NUMBER}} times."
      DisplayName="Process Transaction">
      <State.Entry>
        <Sequence DisplayName="Process Transaction">
          <TryCatch DisplayName="Try Process Transaction">
            <TryCatch.Try>
              <Sequence>
                <Assign DisplayName="Increment TransactionNumber">
                  <Assign.To><OutArgument x:TypeArguments="x:Int32">[TransactionNumber]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:Int32">[TransactionNumber + 1]</InArgument></Assign.Value>
                </Assign>
                <ui:LogMessage Level="Info"
                  Message="['[{{PROCESS_NAME}}] Processing #' + TransactionNumber.ToString() + ' | Ref: ' + TransactionItem.Reference]"
                  DisplayName="Log transaction start" />
                <ui:InvokeWorkflowFile DisplayName="Invoke Process.xaml"
                  WorkflowFileName="Process.xaml" UnSafe="False">
                  <ui:InvokeWorkflowFile.Arguments>
                    <InArgument x:TypeArguments="ui:QueueItem" x:Key="in_TransactionItem">[TransactionItem]</InArgument>
                    <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
                  </ui:InvokeWorkflowFile.Arguments>
                </ui:InvokeWorkflowFile>
                <ui:InvokeWorkflowFile DisplayName="Set status: Successful"
                  WorkflowFileName="Framework\SetTransactionStatus.xaml" UnSafe="False">
                  <ui:InvokeWorkflowFile.Arguments>
                    <InArgument x:TypeArguments="ui:QueueItem" x:Key="in_TransactionItem">[TransactionItem]</InArgument>
                    <InArgument x:TypeArguments="x:String" x:Key="in_TransactionStatus">Successful</InArgument>
                    <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
                  </ui:InvokeWorkflowFile.Arguments>
                </ui:InvokeWorkflowFile>
                <Assign DisplayName="Reset ConsecutiveSystemExceptions">
                  <Assign.To><OutArgument x:TypeArguments="x:Int32">[ConsecutiveSystemExceptions]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:Int32">0</InArgument></Assign.Value>
                </Assign>
                <Assign DisplayName="Clear SystemException">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[SystemException]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:String">&quot;&quot;</InArgument></Assign.Value>
                </Assign>
              </Sequence>
            </TryCatch.Try>
            <TryCatch.Catches>
              <Catch x:TypeArguments="uia:BusinessRuleException">
                <ActivityAction x:TypeArguments="uia:BusinessRuleException">
                  <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="uia:BusinessRuleException" Name="businessException" />
                  </ActivityAction.Argument>
                  <Sequence DisplayName="Handle Business Rule Exception — no retry">
                    <ui:LogMessage Level="Warn"
                      Message="['[{{PROCESS_NAME}}] Business Exception | Ref: ' + TransactionItem.Reference + ' | ' + businessException.Message]"
                      DisplayName="Log BusinessRuleException" />
                    <ui:InvokeWorkflowFile DisplayName="Set status: Failed (Business)"
                      WorkflowFileName="Framework\SetTransactionStatus.xaml" UnSafe="False">
                      <ui:InvokeWorkflowFile.Arguments>
                        <InArgument x:TypeArguments="ui:QueueItem" x:Key="in_TransactionItem">[TransactionItem]</InArgument>
                        <InArgument x:TypeArguments="x:String" x:Key="in_TransactionStatus">Failed</InArgument>
                        <InArgument x:TypeArguments="x:Exception" x:Key="in_TransactionError">[businessException]</InArgument>
                        <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
                      </ui:InvokeWorkflowFile.Arguments>
                    </ui:InvokeWorkflowFile>
                    <Assign DisplayName="Clear SystemException (no retry)">
                      <Assign.To><OutArgument x:TypeArguments="x:String">[SystemException]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">&quot;&quot;</InArgument></Assign.Value>
                    </Assign>
                  </Sequence>
                </ActivityAction>
              </Catch>
              <Catch x:TypeArguments="x:Exception">
                <ActivityAction x:TypeArguments="x:Exception">
                  <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="x:Exception" Name="systemException" />
                  </ActivityAction.Argument>
                  <Sequence DisplayName="Handle System Exception — triggers retry">
                    <ui:LogMessage Level="Error"
                      Message="['[{{PROCESS_NAME}}] System Exception | Ref: ' + TransactionItem.Reference + ' | ' + systemException.Message]"
                      DisplayName="Log SystemException" />
                    <Assign DisplayName="Set SystemException flag">
                      <Assign.To><OutArgument x:TypeArguments="x:String">[SystemException]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[systemException.Message]</InArgument></Assign.Value>
                    </Assign>
                    <Assign DisplayName="Increment ConsecutiveSystemExceptions">
                      <Assign.To><OutArgument x:TypeArguments="x:Int32">[ConsecutiveSystemExceptions]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:Int32">[ConsecutiveSystemExceptions + 1]</InArgument></Assign.Value>
                    </Assign>
                    <ui:InvokeWorkflowFile DisplayName="Set status: Failed (System)"
                      WorkflowFileName="Framework\SetTransactionStatus.xaml" UnSafe="False">
                      <ui:InvokeWorkflowFile.Arguments>
                        <InArgument x:TypeArguments="ui:QueueItem" x:Key="in_TransactionItem">[TransactionItem]</InArgument>
                        <InArgument x:TypeArguments="x:String" x:Key="in_TransactionStatus">Failed</InArgument>
                        <InArgument x:TypeArguments="x:Exception" x:Key="in_TransactionError">[systemException]</InArgument>
                        <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
                      </ui:InvokeWorkflowFile.Arguments>
                    </ui:InvokeWorkflowFile>
                  </Sequence>
                </ActivityAction>
              </Catch>
            </TryCatch.Catches>
          </TryCatch>
        </Sequence>
      </State.Entry>
      <State.Transitions>
        <Transition DisplayName="Success or Business Exc → GetTransactionData" To="GetTransactionData">
          <Transition.Condition>[String.IsNullOrEmpty(SystemException)]</Transition.Condition>
        </Transition>
        <Transition DisplayName="System Exc, retries left → Init" To="Init">
          <Transition.Condition>[Not String.IsNullOrEmpty(SystemException) And ConsecutiveSystemExceptions &lt; {{MAX_RETRY_NUMBER}}]</Transition.Condition>
        </Transition>
        <Transition DisplayName="Max retries exceeded → End" To="End">
          <Transition.Condition>[ConsecutiveSystemExceptions >= {{MAX_RETRY_NUMBER}}]</Transition.Condition>
        </Transition>
      </State.Transitions>
    </State>

    <!-- ══════════════════ END PROCESS STATE ══════════════════════ -->
    <State x:Name="End"
      sap2010:Annotation.AnnotationText="Close all applications gracefully, then kill any lingering processes.&#xA;Log final summary."
      DisplayName="End Process"
      IsFinal="True">
      <State.Entry>
        <Sequence DisplayName="End Process">
          <ui:InvokeWorkflowFile DisplayName="Invoke CloseAllApplications"
            WorkflowFileName="Framework\CloseAllApplications.xaml" UnSafe="False">
            <ui:InvokeWorkflowFile.Arguments>
              <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>
          <ui:InvokeWorkflowFile DisplayName="Invoke KillAllProcesses"
            WorkflowFileName="Framework\KillAllProcesses.xaml" UnSafe="False" />
          <If Condition="[ConsecutiveSystemExceptions >= {{MAX_RETRY_NUMBER}}]"
            DisplayName="Aborted by max retries?">
            <If.Then>
              <ui:LogMessage Level="Fatal"
                Message="['[{{PROCESS_NAME}}] ABORTED: Max consecutive system exceptions reached (' + ConsecutiveSystemExceptions.ToString() + '). Last error: ' + SystemException]"
                DisplayName="Log abort reason" />
            </If.Then>
            <If.Else>
              <ui:LogMessage Level="Info"
                Message="['[{{PROCESS_NAME}}] Process completed normally. Total transactions processed: ' + TransactionNumber.ToString()]"
                DisplayName="Log normal end" />
            </If.Else>
          </If>
        </Sequence>
      </State.Entry>
    </State>

  </StateMachine>
</Activity>
