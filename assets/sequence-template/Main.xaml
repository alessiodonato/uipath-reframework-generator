<!--
  Main.xaml - Sequence Template
  Simple linear automation without transaction loop.
  Generated by ReFramework Generator v{{VERSION}} on {{CURRENT_DATE}}
-->
<Activity
  mc:Ignorable="sap sap2010"
  x:Class="UiPath.{{PROCESS_NAME}}.Main"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:s="clr-namespace:System;assembly=mscorlib"
  xmlns:sd="clr-namespace:System.Data;assembly=System.Data"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <mva:VisualBasic.Settings>
    <mva:VisualBasicSettings>
      <mva:VisualBasicSettings.ImportedNamespaces>
        <mva:VisualBasicImportReference Assembly="mscorlib" Import="System" />
        <mva:VisualBasicImportReference Assembly="System.Data" Import="System.Data" />
        <mva:VisualBasicImportReference Assembly="UiPath.Core" Import="UiPath.Core" />
      </mva:VisualBasicSettings.ImportedNamespaces>
    </mva:VisualBasicSettings>
  </mva:VisualBasic.Settings>

  <Sequence
    DisplayName="{{PROCESS_NAME}} - Main"
    sap2010:Annotation.AnnotationText="{{PROCESS_DESCRIPTION}}&#xA;&#xA;Sequence process - no transaction loop.&#xA;Uses TryCatch for error handling.">

    <Sequence.Variables>
      <Variable x:TypeArguments="scg:Dictionary(x:String, x:Object)" Name="Config" />
      <Variable x:TypeArguments="x:Boolean" Name="ProcessSuccess" Default="False" />
      <Variable x:TypeArguments="s:Exception" Name="ProcessException" />
    </Sequence.Variables>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- INITIALIZATION                                                        -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <ui:LogMessage Level="Info"
      Message="'[{{PROCESS_NAME}}] Process started'"
      DisplayName="Log: Process started" />

    <TryCatch DisplayName="Main Process TryCatch">
      <TryCatch.Try>
        <Sequence DisplayName="Process Flow">

          <!-- Load Configuration -->
          <ui:InvokeWorkflowFile
            DisplayName="Load Configuration"
            WorkflowFileName="Framework\InitAllSettings.xaml">
            <ui:InvokeWorkflowFile.Arguments>
              <InArgument x:TypeArguments="x:String" x:Key="in_ConfigFile">["Data\Config.xlsx"]</InArgument>
              <InArgument x:TypeArguments="s:String[]" x:Key="in_ConfigSheets">[{"Settings", "Constants"}]</InArgument>
              <OutArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="out_Config">[Config]</OutArgument>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <!-- Initialize Applications -->
          <ui:InvokeWorkflowFile
            DisplayName="Initialize Applications"
            WorkflowFileName="Framework\InitAllApplications.xaml">
            <ui:InvokeWorkflowFile.Arguments>
              <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <!-- ════════════════════════════════════════════════════════════ -->
          <!-- MAIN PROCESS STEPS                                           -->
          <!-- ════════════════════════════════════════════════════════════ -->

{{PROCESS_STEPS_PLACEHOLDER}}

          <!-- Mark Success -->
          <Assign DisplayName="Set ProcessSuccess = True">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[ProcessSuccess]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">[True]</InArgument></Assign.Value>
          </Assign>

        </Sequence>
      </TryCatch.Try>

      <TryCatch.Catches>
        <!-- Business Rule Exception - Log and continue -->
        <Catch x:TypeArguments="ui:BusinessRuleException">
          <ActivityAction x:TypeArguments="ui:BusinessRuleException">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="ui:BusinessRuleException" Name="businessEx" />
            </ActivityAction.Argument>
            <Sequence DisplayName="Handle Business Exception">
              <Assign DisplayName="Store exception">
                <Assign.To><OutArgument x:TypeArguments="s:Exception">[ProcessException]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="s:Exception">[businessEx]</InArgument></Assign.Value>
              </Assign>
              <ui:LogMessage Level="Warn"
                Message="['[{{PROCESS_NAME}}] Business rule exception: ' + businessEx.Message]"
                DisplayName="Log: Business exception" />
            </Sequence>
          </ActivityAction>
        </Catch>

        <!-- System Exception - Log error -->
        <Catch x:TypeArguments="s:Exception">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="systemEx" />
            </ActivityAction.Argument>
            <Sequence DisplayName="Handle System Exception">
              <Assign DisplayName="Store exception">
                <Assign.To><OutArgument x:TypeArguments="s:Exception">[ProcessException]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="s:Exception">[systemEx]</InArgument></Assign.Value>
              </Assign>
              <ui:LogMessage Level="Error"
                Message="['[{{PROCESS_NAME}}] System exception: ' + systemEx.Message]"
                DisplayName="Log: System exception" />
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>

      <TryCatch.Finally>
        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- CLEANUP                                                       -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Sequence DisplayName="Cleanup">
          <ui:InvokeWorkflowFile
            DisplayName="Close All Applications"
            WorkflowFileName="Framework\CloseAllApplications.xaml">
            <ui:InvokeWorkflowFile.Arguments>
              <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Object)" x:Key="in_Config">[Config]</InArgument>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>
        </Sequence>
      </TryCatch.Finally>
    </TryCatch>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- FINAL STATUS                                                          -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <If Condition="[ProcessSuccess]" DisplayName="Check process result">
      <If.Then>
        <ui:LogMessage Level="Info"
          Message="'[{{PROCESS_NAME}}] Process completed successfully'"
          DisplayName="Log: Process success" />
      </If.Then>
      <If.Else>
        <Sequence DisplayName="Process failed">
          <ui:LogMessage Level="Error"
            Message="['[{{PROCESS_NAME}}] Process failed: ' + If(ProcessException IsNot Nothing, ProcessException.Message, &quot;Unknown error&quot;)]"
            DisplayName="Log: Process failed" />
          <!-- Optionally rethrow to mark job as failed in Orchestrator -->
          <!-- <Throw Exception="[ProcessException]" DisplayName="Rethrow exception" /> -->
        </Sequence>
      </If.Else>
    </If>

  </Sequence>
</Activity>
